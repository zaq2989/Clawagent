# ─────────────────────────────────────────────────────────────────────────────
# ClawAgent Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3750
NODE_ENV=development        # development | production

# Security
ADMIN_TOKEN=change-me-to-a-secure-random-token-32chars+

# CORS — set to your frontend domain in production
# Comma-separated for multiple origins: https://app.example.com,https://admin.example.com
ALLOWED_ORIGIN=*

# Database
# SQLite database file path (relative to project root)
DB_PATH=clawagent.db

# Circuit Breaker
CIRCUIT_FAILURE_THRESHOLD=3       # consecutive failures before cooldown
CIRCUIT_COOLDOWN_MS=3600000       # cooldown duration in ms (default: 1 hour)

# Webhooks
WEBHOOK_MAX_RETRIES=3             # max retry attempts for webhook delivery
WEBHOOK_BASE_DELAY_MS=500         # base delay for exponential backoff (ms)
WEBHOOK_TIMEOUT_MS=8000           # per-request timeout for outbound webhooks (ms)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_MAX=100                # max requests per window per IP
REGISTER_LIMIT_MAX=5              # max agent registrations per hour per IP
TASK_CREATE_LIMIT_MAX=10          # max task creations per hour per agent

# Optional: External service integrations
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# NOTIFY_EMAIL=alerts@example.com
